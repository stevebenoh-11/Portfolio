datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Submission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String   @default("Not Provided")
  subject   String   @default("General Inquiry")
  message   String
  createdAt DateTime @default(now())
}
